{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["idea"],
  "properties": {
    "name": {"type": "string", "minLength": 1},
    "idea": {"type": "string", "minLength": 20},
    "target_users": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "business_model": {"type": "string", "minLength": 1},
    "evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "constraints": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "non_goals": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "design_preferences": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "brand_references": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "brand_anti_references": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "framework_constraints": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "asset_requirements": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "copy_constraints": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "locales": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "required_channels": {"type": "array", "uniqueItems": true, "items": {"enum": ["landing", "product", "checkout", "onboarding", "account", "support"]}},
    "audience_language_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["audience", "phrase", "source"],
        "properties": {
          "audience": {"type": "string", "minLength": 1},
          "phrase": {"type": "string", "minLength": 1},
          "source": {"type": "string", "minLength": 1}
        }
      }
    },
    "claim_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "source"],
        "properties": {
          "claim": {"type": "string", "minLength": 1},
          "source": {"type": "string", "minLength": 1},
          "qualification": {"type": "string"},
          "freshness": {"type": "string"}
        }
      }
    },
    "stack_overrides": {"type": "object", "additionalProperties": {"type": "string"}}
  }
}
