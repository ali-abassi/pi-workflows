{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/certification-corpus.schema.json",
  "title": "Deterministic workflow certification corpus",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "workflow", "cases"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "workflow": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "cases": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "class", "input", "expected", "evidence_requirements"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "class": {"enum": ["positive", "adversarial", "regression", "integration", "safety"]},
          "input": {},
          "expected": {},
          "evidence_requirements": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
