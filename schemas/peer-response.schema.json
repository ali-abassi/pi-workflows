{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/peer-response.schema.json",
  "title": "Deterministic workflow peer response",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "message_id", "correlation_id", "in_reply_to", "stage", "sender", "recipient", "hop", "completed_at", "status", "summary", "findings", "error"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "message_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"},
    "correlation_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"},
    "in_reply_to": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"},
    "stage": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "sender": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"},
    "recipient": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"},
    "hop": {"type": "integer", "minimum": 0},
    "completed_at": {"type": "string", "format": "date-time"},
    "status": {"enum": ["completed", "insufficient_evidence", "error"]},
    "summary": {"type": "string"},
    "findings": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "claim", "evidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"},
          "severity": {"enum": ["info", "low", "medium", "high", "critical"]},
          "claim": {"type": "string", "minLength": 1},
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source", "locator"],
              "properties": {
                "source": {"type": "string", "minLength": 1},
                "locator": {"type": "string", "minLength": 1},
                "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
              }
            }
          }
        }
      }
    },
    "error": {"type": ["string", "null"]}
  }
}
