{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/workflow-blueprint.schema.json",
  "title": "Deterministic workflow factory blueprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "workflow", "version", "description", "effect",
    "runtime", "objective_contract", "lifecycle", "acceptance_criteria",
    "verifiers", "task_template", "context_policy", "operations"
  ],
  "allOf": [
    {
      "if": {"required": ["control_flow"]},
      "then": {
        "properties": {
          "schema_version": {"enum": ["1.1", "1.2", "1.3"]},
          "runtime": {
            "properties": {"kind": {"const": "specialized"}},
            "required": ["kind"]
          }
        }
      }
    },
    {
      "if": {"required": ["peer_collaboration"]},
      "then": {
        "properties": {
          "schema_version": {"enum": ["1.2", "1.3"]},
          "runtime": {
            "properties": {"kind": {"const": "specialized"}},
            "required": ["kind"]
          }
        }
      }
    },
    {
      "if": {"properties": {"schema_version": {"const": "1.3"}}, "required": ["schema_version"]},
      "then": {"required": ["certification_contract"]}
    },
    {
      "if": {"required": ["certification_contract"]},
      "then": {"properties": {"schema_version": {"const": "1.3"}}}
    }
  ],
  "properties": {
    "schema_version": {"enum": ["1.0", "1.1", "1.2", "1.3"]},
    "workflow": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[a-z0-9.-]+)?$"},
    "description": {"type": "string", "minLength": 1},
    "effect": {"enum": ["mutation", "read_only"]},
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"enum": ["generic_mutation", "specialized"]},
        "entrypoint": {"type": "string", "minLength": 1}
      }
    },
    "objective_contract": {
      "type": "object", "additionalProperties": false,
      "required": ["selector", "target", "decision", "non_goals"],
      "properties": {
        "selector": {"type": "string", "minLength": 1},
        "target": {"type": "string", "minLength": 1},
        "decision": {"type": "string", "minLength": 1},
        "non_goals": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "lifecycle": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}},
    "models": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intake", "plan", "execute", "repair", "judge"],
      "properties": {
        "intake": {"type": "string", "pattern": "^[^/ ]+/[^ ]+$"},
        "plan": {"type": "string", "pattern": "^[^/ ]+/[^ ]+$"},
        "execute": {"type": "string", "pattern": "^[^/ ]+/[^ ]+$"},
        "repair": {"type": "string", "pattern": "^[^/ ]+/[^ ]+$"},
        "judge": {"type": "string", "pattern": "^[^/ ]+/[^ ]+$"}
      }
    },
    "stage_capabilities": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9-]*$"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tools"],
        "properties": {
          "tools": {
            "type": "array",
            "uniqueItems": true,
            "items": {"enum": ["read", "bash", "edit", "write", "grep", "find", "ls"]}
          }
        }
      }
    },
    "control_flow": {
      "type": "object", "additionalProperties": false,
      "required": ["initial_stage", "terminal_stages", "max_transitions", "max_visits_per_stage", "on_exhausted", "transitions"],
      "properties": {
        "initial_stage": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "terminal_stages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}},
        "max_transitions": {"type": "integer", "minimum": 1, "maximum": 1000},
        "max_visits_per_stage": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 1, "maximum": 50}},
        "on_exhausted": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "transitions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/transition"}}
      }
    },
    "peer_collaboration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages", "peers", "transport", "limits", "required_responses", "on_unavailable", "logging"],
      "properties": {
        "stages": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}
        },
        "peers": {
          "type": "array", "minItems": 1, "maxItems": 8,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "purpose", "model", "thinking", "tools"],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
              "purpose": {"type": "string", "minLength": 1},
              "model": {"type": "string", "pattern": "^[^/]+/.+$"},
              "thinking": {"enum": ["off", "minimal", "low", "medium", "high"]},
              "tools": {
                "type": "array", "uniqueItems": true,
                "items": {"enum": ["read", "bash", "edit", "write", "grep", "find", "ls"]}
              }
            }
          }
        },
        "transport": {
          "oneOf": [
            {
              "type": "object", "additionalProperties": false,
              "required": ["kind", "authentication"],
              "properties": {
                "kind": {"const": "local_socket"},
                "authentication": {"const": "os_user"}
              }
            },
            {
              "type": "object", "additionalProperties": false,
              "required": ["kind", "authentication", "endpoint_env"],
              "properties": {
                "kind": {"const": "http_sse"},
                "authentication": {"enum": ["per_agent_token", "mtls"]},
                "endpoint_env": {"type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$"}
              }
            }
          ]
        },
        "limits": {
          "type": "object", "additionalProperties": false,
          "required": ["max_messages", "max_hops", "timeout_seconds", "max_response_bytes"],
          "properties": {
            "max_messages": {"type": "integer", "minimum": 1, "maximum": 100},
            "max_hops": {"type": "integer", "minimum": 1, "maximum": 20},
            "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
            "max_response_bytes": {"type": "integer", "minimum": 1024, "maximum": 1048576}
          }
        },
        "required_responses": {"type": "integer", "minimum": 1, "maximum": 8},
        "on_unavailable": {"enum": ["fail_stage", "continue_with_degraded_evidence"]},
        "logging": {"const": "metadata_only"}
      }
    },
    "certification_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corpus", "deterministic_gates", "judges", "dimensions", "replay", "promotion"],
      "properties": {
        "corpus": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "minimum_cases", "required_classes"],
          "properties": {
            "path": {"type": "string", "pattern": "^[^/].*\\.json$"},
            "minimum_cases": {"type": "integer", "minimum": 3},
            "required_classes": {
              "type": "array",
              "minItems": 3,
              "uniqueItems": true,
              "contains": {"const": "positive"},
              "allOf": [
                {"contains": {"const": "adversarial"}},
                {"contains": {"const": "regression"}}
              ],
              "items": {"enum": ["positive", "adversarial", "regression", "integration", "safety"]}
            }
          }
        },
        "deterministic_gates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}
        },
        "judges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "rubric_path", "model", "threshold", "evidence_fields"],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
              "rubric_path": {"type": "string", "pattern": "^[^/].*\\.json$"},
              "model": {"type": "string", "minLength": 1},
              "threshold": {"type": "number", "minimum": 0, "maximum": 10},
              "evidence_fields": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        },
        "dimensions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["truth", "eval_quality", "cost_efficiency", "integration", "safety"],
          "properties": {
            "truth": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
            "eval_quality": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
            "cost_efficiency": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
            "integration": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
            "safety": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
          }
        },
        "replay": {
          "type": "object",
          "additionalProperties": false,
          "required": ["same_corpus", "max_cost_regression_percent", "max_latency_regression_percent"],
          "properties": {
            "baseline_version": {"type": ["string", "null"], "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[a-z0-9.-]+)?$"},
            "same_corpus": {"const": true},
            "max_cost_regression_percent": {"type": "number", "minimum": 0},
            "max_latency_regression_percent": {"type": "number", "minimum": 0}
          }
        },
        "promotion": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimum_pass_rate", "minimum_dimension_score", "require_independent_validation", "require_operator_decision", "block_on_regression"],
          "properties": {
            "minimum_pass_rate": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
            "minimum_dimension_score": {"type": "number", "minimum": 0, "maximum": 10},
            "require_independent_validation": {"const": true},
            "require_operator_decision": {"const": true},
            "block_on_regression": {"const": true}
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}, "description": {"type": "string", "minLength": 1}}
      }
    },
    "verifiers": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "covers", "command"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "covers": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "timeout_seconds": {"type": "integer", "minimum": 1}
        }
      }
    },
    "task_template": {
      "type": "object", "additionalProperties": false,
      "required": ["task_id", "objective", "inputs", "immutable_paths", "allowed_write_paths", "fixture_files"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "objective": {"type": "string", "minLength": 1},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "immutable_paths": {"type": "array", "items": {"type": "string"}},
        "allowed_write_paths": {"type": "array", "items": {"type": "string"}},
        "constraints": {"type": "array", "items": {"type": "string"}},
        "required_steps": {"type": "array", "maxItems": 50, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "fixture_files": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string"}},
        "max_repairs": {"type": "integer", "minimum": 0, "maximum": 3}
      }
    },
    "context_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["strategy", "max_input_bytes"],
      "properties": {
        "strategy": {"enum": ["full", "deterministic_segments", "hierarchical_chunks"]},
        "max_input_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "operations": {
      "type": "object", "additionalProperties": false,
      "required": ["owner", "concurrency", "retention_days", "redact_patterns", "failure_response"],
      "properties": {
        "owner": {"type": "string", "minLength": 1},
        "concurrency": {"enum": ["isolated_workspace", "read_only_shared"]},
        "retention_days": {"type": "integer", "minimum": 1},
        "redact_patterns": {"type": "array", "items": {"type": "string"}},
        "failure_response": {"type": "string", "minLength": 1}
      }
    }
  },
  "$defs": {
    "condition": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["op", "args"], "properties": {"op": {"enum": ["all", "any"]}, "args": {"type": "array", "minItems": 1, "maxItems": 50, "items": {"$ref": "#/$defs/condition"}}}},
        {"type": "object", "additionalProperties": false, "required": ["op", "arg"], "properties": {"op": {"const": "not"}, "arg": {"$ref": "#/$defs/condition"}}},
        {"type": "object", "additionalProperties": false, "required": ["op", "path"], "properties": {"op": {"enum": ["exists", "missing"]}, "path": {"type": "string", "maxLength": 512}}},
        {"type": "object", "additionalProperties": false, "required": ["op", "path", "value"], "properties": {"op": {"enum": ["type_is", "equals", "not_equals", "less_than", "less_than_or_equal", "greater_than", "greater_than_or_equal", "contains", "in"]}, "path": {"type": "string", "maxLength": 512}, "value": {}}}
      ]
    },
    "transition": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["id", "from", "to", "priority", "when"], "properties": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}, "from": {"type": "string"}, "to": {"type": "string"}, "priority": {"type": "integer", "minimum": 0, "maximum": 10000}, "when": {"$ref": "#/$defs/condition"}}},
        {"type": "object", "additionalProperties": false, "required": ["id", "from", "to", "priority", "default"], "properties": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}, "from": {"type": "string"}, "to": {"type": "string"}, "priority": {"type": "integer", "minimum": 0, "maximum": 10000}, "default": {"const": true}}}
      ]
    }
  }
}
