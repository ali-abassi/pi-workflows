{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/peer-request.schema.json",
  "title": "Deterministic workflow peer request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "message_id", "correlation_id", "stage", "sender", "recipient", "hop", "sent_at", "payload"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "message_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"},
    "correlation_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"},
    "stage": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "sender": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"},
    "recipient": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"},
    "hop": {"type": "integer", "minimum": 0},
    "sent_at": {"type": "string", "format": "date-time"},
    "payload": {"type": "object"}
  }
}
