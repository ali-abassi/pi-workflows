#!/bin/sh
set -eu

script=$0
while [ -L "$script" ]; do
  target=$(readlink "$script")
  case "$target" in /*) script=$target ;; *) script=$(dirname -- "$script")/$target ;; esac
done
root=$(CDPATH= cd -- "$(dirname -- "$script")/.." && pwd)
python_bin=${PI_WORKFLOWS_PYTHON:-"$root/.venv/bin/python"}

if [ ! -x "$python_bin" ]; then
  python_bin=python3
fi

exec "$python_bin" "$root/scripts/piw.py" "$@"
